      "input": {
        "theme": "电子音乐节",
        "industry": "娱乐",
        "targetAudience": "年轻人",
        "textConfig": {
          "title": "2026 未来科技峰会",
          "subtitle": "探索·创新·突破",
          "bodyText": "2026 年 3 月 15-17 日 | 北京·国家会议中心",
          "position": "顶部居中",
          "titleStyle": {
            "fontFamily": "思源黑体 Bold",
            "fontSize": "超大 (占画面 20-30%)",
