{
  "name": "midjourney-style-matcher",
  "version": "1.0.0",
  "description": "Midjourney 艺术风格匹配引擎 - 根据主题自动匹配艺术流派、代表艺术家、色彩调性、视觉关键词（中文文字 + 英文提示词 + 中文解析）",
  "author": "Poster Design AI Team",
  "license": "MIT",
  "type": "style-engine",
  "platform": "midjourney",
  "category": "art-direction",
  "tags": [
    "style",
    "artist",
    "art-movement",
    "color-theory",
    "midjourney"
  ],
  "systemPrompt": "你是艺术风格专家，精通艺术史、现代设计、当代艺术趋势。根据用户输入的主题或使用场景，自动匹配最适合的艺术流派、代表艺术家、色彩调性、视觉关键词，并生成英文提示词和中文解析。\n\n重要要求：海报上的所有文字必须使用中文（汉字），包括标题、副标题、正文、装饰文字等。使用专业中文字体（如思源黑体、站酷高端黑、造字工房字体等），确保中文排版美观可读。\n\n\n  \n文字配置功能（可选）：\n如果用户提供文字配置，请严格按照以下要求生成提示词：\n- 文字内容：使用用户指定的确切文字\n- 文字位置：按照用户要求布局（顶部居中、底部居右、左侧垂直等）\n- 文字样式：使用指定的字体风格（粗体、细体、书法体等）\n- 文字格式：控制字号大小、颜色、透明度、间距等\n- 文字效果：添加阴影、描边、发光、渐变等特效\n\n如果没有提供文字配置，则自动根据主题生成合适的中文文字。\n\n输出格式：\n【艺术流派】英文 + 中文翻译\n【代表艺术家】英文 + 中文翻译\n【色彩调性】英文 + 中文翻译\n【视觉关键词】英文 + 中文翻译\n【推荐风格组合】英文提示词 + 中文翻译\n【提示词解析】解释每个组成部分的作用",
  "inputSchema": {
    "type": "object",
    "properties": {
      "theme": {
        "type": "string",
        "description": "主题或使用场景（如：音乐节、科技发布会、艺术展、品牌宣传等）",
        "required": true
      },
      "industry": {
        "type": "string",
        "description": "所属行业（如：科技、时尚、文化、教育、金融等）",
        "required": false
      },
      "targetAudience": {
        "type": "string",
        "description": "目标受众（如：年轻人、专业人士、高端客户、大众等）",
        "required": false
      },
      "textConfig": {
        "type": "object",
        "description": "文字配置（可选），用于精确控制海报上的文字内容、位置、样式和格式",
        "properties": {
          "title": {
            "type": "string",
            "description": "主标题文字内容（如：\"2026 未来科技峰会\"）"
          },
          "subtitle": {
            "type": "string",
            "description": "副标题文字内容（如：\"探索·创新·突破\"）"
          },
          "bodyText": {
            "type": "string",
            "description": "正文文字内容（如：活动时间、地点、主办方等详细信息）"
          },
          "position": {
            "type": "string",
            "description": "文字整体布局位置",
            "enum": [
              "顶部居中",
              "顶部居左",
              "顶部居右",
              "中部居中",
              "中部居左",
              "中部居右",
              "底部居中",
              "底部居左",
              "底部居右",
              "左侧垂直",
              "右侧垂直",
              "自定义位置"
            ]
          },
          "titleStyle": {
            "type": "object",
            "description": "主标题样式配置",
            "properties": {
              "fontFamily": {
                "type": "string",
                "description": "字体名称（如：思源黑体 Bold、站酷高端黑、书法体等）",
                "enum": [
                  "思源黑体 Bold",
                  "思源黑体 Regular",
                  "思源宋体 Bold",
                  "思源宋体 Regular",
                  "站酷高端黑",
                  "站酷黄油体",
                  "阿里巴巴普惠体 Bold",
                  "书法体",
                  "手写体",
                  "艺术字体"
                ]
              },
              "fontSize": {
                "type": "string",
                "description": "字号大小",
                "enum": [
                  "超大 (占画面 20-30%)",
                  "大 (占画面 15-20%)",
                  "中 (占画面 10-15%)",
                  "小 (占画面 5-10%)"
                ]
              },
              "fontWeight": {
                "type": "string",
                "description": "字体粗细",
                "enum": [
                  "特粗",
                  "粗体",
                  "常规",
                  "细体",
                  "特细"
                ]
              },
              "color": {
                "type": "string",
                "description": "文字颜色（如：白色、金色渐变、霓虹蓝色等）"
              },
              "spacing": {
                "type": "string",
                "description": "字间距",
                "enum": [
                  "特宽",
                  "宽",
                  "正常",
                  "窄",
                  "特窄"
                ]
              }
            }
          },
          "subtitleStyle": {
            "type": "object",
            "description": "副标题样式配置",
            "properties": {
              "fontFamily": {
                "type": "string",
                "description": "字体名称"
              },
              "fontSize": {
                "type": "string",
                "description": "字号大小",
                "enum": [
                  "大",
                  "中",
                  "小",
                  "微小"
                ]
              },
              "fontWeight": {
                "type": "string",
                "description": "字体粗细",
                "enum": [
                  "粗体",
                  "常规",
                  "细体"
                ]
              },
              "color": {
                "type": "string",
                "description": "文字颜色"
              }
            }
          },
          "effects": {
            "type": "object",
            "description": "文字特效配置",
            "properties": {
              "shadow": {
                "type": "string",
                "description": "阴影效果",
                "enum": [
                  "无",
                  "轻微阴影",
                  "明显阴影",
                  "发光阴影"
                ]
              },
              "stroke": {
                "type": "string",
                "description": "描边效果",
                "enum": [
                  "无",
                  "细描边",
                  "中描边",
                  "粗描边"
                ]
              },
              "glow": {
                "type": "string",
                "description": "发光效果",
                "enum": [
                  "无",
                  "微弱发光",
                  "明显发光",
                  "强烈发光"
                ]
              },
              "gradient": {
                "type": "string",
                "description": "渐变效果",
                "enum": [
                  "无",
                  "线性渐变",
                  "径向渐变",
                  "角度渐变"
                ]
              }
            }
          }
        }
      }
    }
  },
  "outputFormat": "bilingual-style-guide",
