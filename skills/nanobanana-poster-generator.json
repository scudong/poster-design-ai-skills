{
  "name": "nanobanana-poster-generator",
  "version": "1.0.0",
  "description": "NanoBanana 主海报生成 - 专为 NanoBanana 优化的海报提示词生成器，强化角色一致性和 IP 稳定性",
  "author": "Poster Design AI Team",
  "license": "MIT",
  "type": "prompt-generator",
  "platform": "nanobanana",
  "category": "poster-design",
  "tags": [
    "poster",
    "nanobanana",
    "prompt",
    "character-consistency",
    "ip-design"
  ],
  "systemPrompt": "你是 NanoBanana 角色稳定专家兼专业艺术策展设计师。根据用户输入的主题、风格、氛围，生成可粘贴到 NanoBanana 的完整海报提示词。必须强制包含：角色形象描述、服装细节、表情姿态、比例设定、主题场景、艺术风格、构图方式、光影效果、色彩方案、材质质感、IP 识别元素。所有角色相关描述必须具体明确，确保多图系列不崩坏、IP 高度统一。输出纯提示词，不解释、不换行、不废话，所有关键词用逗号分隔，保持单段连续文本。\n\n重要：海报上的文字必须使用中文（汉字），包括标题、副标题、正文等所有文字元素。确保中文字体清晰可读，使用专业中文字体（如思源黑体、站酷高端黑、造字工房字体等）。\n  \n文字配置功能（可选）：\n如果用户提供文字配置，请严格按照以下要求生成提示词：\n- 文字内容：使用用户指定的确切文字\n- 文字位置：按照用户要求布局（顶部居中、底部居右、左侧垂直等）\n- 文字样式：使用指定的字体风格（粗体、细体、书法体等）\n- 文字格式：控制字号大小、颜色、透明度、间距等\n- 文字效果：添加阴影、描边、发光、渐变等特效\n\n如果没有提供文字配置，则自动根据主题生成合适的中文文字。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "theme": {
        "type": "string",
        "description": "海报主题",
        "required": true
      },
      "character": {
        "type": "string",
        "description": "角色描述（如：年轻女性、商务男士、卡通吉祥物等）",
        "required": false
      },
      "characterFeatures": {
        "type": "string",
        "description": "角色特征细节（发型、发色、眼睛、服装、配饰等）",
        "required": false
      },
      "style": {
        "type": "string",
        "description": "艺术风格",
        "required": false
      },
      "mood": {
        "type": "string",
        "description": "氛围情绪",
        "required": false
      },
      "colorScheme": {
        "type": "string",
        "description": "色彩方案",
        "required": false
      },
      "aspectRatio": {
        "type": "string",
        "description": "画面比例",
        "required": false,
        "default": "2:3"
      },
      "textConfig": {
        "type": "object",
        "description": "文字配置（可选），用于精确控制海报上的文字内容、位置、样式和格式",
        "properties": {
          "title": {
            "type": "string",
            "description": "主标题文字内容（如：\"2026 未来科技峰会\"）"
          },
          "subtitle": {
            "type": "string",
            "description": "副标题文字内容（如：\"探索·创新·突破\"）"
          },
          "bodyText": {
            "type": "string",
            "description": "正文文字内容（如：活动时间、地点、主办方等详细信息）"
          },
          "position": {
            "type": "string",
            "description": "文字整体布局位置",
            "enum": [
              "顶部居中",
              "顶部居左",
              "顶部居右",
              "中部居中",
              "中部居左",
              "中部居右",
              "底部居中",
              "底部居左",
              "底部居右",
              "左侧垂直",
              "右侧垂直",
              "自定义位置"
            ]
          },
          "titleStyle": {
            "type": "object",
            "description": "主标题样式配置",
            "properties": {
              "fontFamily": {
                "type": "string",
                "description": "字体名称（如：思源黑体 Bold、站酷高端黑、书法体等）",
                "enum": [
                  "思源黑体 Bold",
                  "思源黑体 Regular",
                  "思源宋体 Bold",
                  "思源宋体 Regular",
                  "站酷高端黑",
                  "站酷黄油体",
                  "阿里巴巴普惠体 Bold",
                  "书法体",
                  "手写体",
                  "艺术字体"
                ]
              },
              "fontSize": {
                "type": "string",
                "description": "字号大小",
                "enum": [
                  "超大 (占画面 20-30%)",
                  "大 (占画面 15-20%)",
                  "中 (占画面 10-15%)",
                  "小 (占画面 5-10%)"
                ]
              },
              "fontWeight": {
                "type": "string",
                "description": "字体粗细",
                "enum": [
                  "特粗",
                  "粗体",
                  "常规",
                  "细体",
                  "特细"
                ]
              },
              "color": {
                "type": "string",
                "description": "文字颜色（如：白色、金色渐变、霓虹蓝色等）"
              },
              "spacing": {
                "type": "string",
                "description": "字间距",
                "enum": [
                  "特宽",
                  "宽",
                  "正常",
                  "窄",
                  "特窄"
                ]
              }
            }
          },
          "subtitleStyle": {
            "type": "object",
            "description": "副标题样式配置",
            "properties": {
              "fontFamily": {
                "type": "string",
                "description": "字体名称"
              },
              "fontSize": {
                "type": "string",
                "description": "字号大小",
                "enum": [
                  "大",
                  "中",
                  "小",
                  "微小"
                ]
              },
              "fontWeight": {
                "type": "string",
                "description": "字体粗细",
                "enum": [
                  "粗体",
                  "常规",
                  "细体"
                ]
              },
              "color": {
                "type": "string",
                "description": "文字颜色"
              }
            }
          },
          "effects": {
            "type": "object",
            "description": "文字特效配置",
            "properties": {
              "shadow": {
                "type": "string",
                "description": "阴影效果",
                "enum": [
                  "无",
                  "轻微阴影",
                  "明显阴影",
                  "发光阴影"
                ]
              },
              "stroke": {
                "type": "string",
                "description": "描边效果",
                "enum": [
                  "无",
                  "细描边",
                  "中描边",
                  "粗描边"
                ]
              },
              "glow": {
                "type": "string",
                "description": "发光效果",
                "enum": [
                  "无",
                  "微弱发光",
                  "明显发光",
                  "强烈发光"
                ]
              },
              "gradient": {
                "type": "string",
                "description": "渐变效果",
                "enum": [
                  "无",
                  "线性渐变",
                  "径向渐变",
                  "角度渐变"
                ]
              }
            }
          }
        }
      }
    }
  },
  "outputFormat": "pure-prompt-with-character-lock",
  "promptTemplate": "{characterDefinition}, {characterFeatures}, {pose}, {theme} poster, {style} style, {composition}, {lighting}, {colorPalette}, {texture}, {ipElements}, {typographyHierarchy}, {resolution}, {mood}, character consistency lock, IP stable, professional poster design --ar {aspectRatio} --nb-v1",
  "characterLockKeywords": {
    "identity": "character identity lock, consistent facial features, stable character design",
    "proportions": "consistent body proportions, fixed height ratio, stable character scale",
    "costume": "unchanged costume design, consistent clothing details, stable accessory placement",
    "expression": "consistent expression style, stable emotion presentation",
    "color": "fixed character color palette, stable skin tone, consistent hair color"
  },
  "examples": [
    {
      "input": {
