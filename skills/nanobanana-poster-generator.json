      },
      "output": "Young female tech blogger character, silver short bob haircut, blue eyes, wearing minimalist white tech dress, transparent holographic glasses, holding glowing tablet device, character identity lock, consistent facial features, stable character design, consistent body proportions, unchanged costume design, consistent expression style, fixed character color palette, technology product launch poster, futuristic tech style, center composition with hero pose, studio lighting with rim light, white silver neon blue color scheme, clean metallic texture, holographic UI elements, bold sans-serif typography hierarchy, 8K resolution, professional confident mood, character consistency lock, IP stable, professional poster design --ar 2:3 --nb-v1"
    }
  ],
  "parameters": {
    "temperature": 0.7,
    "maxTokens": 600,
    "topP": 0.9
  },
  "metadata": {
    "createdAt": "2026-03-13",
    "updatedAt": "2026-03-13",
    "skillLevel": "professional",
    "targetUsers": [
      "character-designers",
      "ip-creators",
      "brand-designers",
      "illustrators"
    ]
  }
}
